generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model google_ads_data {
  id          Int      @id @default(autoincrement())
  account_id  String   @db.VarChar(100)
  date        DateTime @db.Date
  spend       Decimal  @db.Decimal(12, 2)
  impressions Int
}

model meta_ads_data {
  id          Int      @id @default(autoincrement())
  account_id  String   @db.VarChar(100)
  date        DateTime @db.Date
  spend       Decimal  @db.Decimal(12, 2)
  impressions Int
}

model organization {
  id                Int       @id @default(autoincrement())
  name              String    @db.VarChar(255)
  meta_account_id   String    @db.VarChar(100)
  google_account_id String    @db.VarChar(100)
  store_id          String    @db.VarChar(100)
  created_at        DateTime? @default(now()) @db.Timestamp(6)
}

model store_data {
  id       Int      @id @default(autoincrement())
  store_id String   @db.VarChar(100)
  date     DateTime @db.Date
  revenue  Decimal  @db.Decimal(12, 2)
  orders   Int
  fees     Decimal  @db.Decimal(12, 2)
}
